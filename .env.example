# Database
POSTGRES_DB=chatdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Backend
JWT_SECRET=replace-with-strong-secret
JWT_TTL_MINUTES=1440
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
DB_CONN_MAX_LIFETIME_MINUTES=5
RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=10

# Reverse Proxy / TLS
# Use your public domain in production, e.g. chat.example.com
DOMAIN=localhost
# Required for Let's Encrypt in production
ACME_EMAIL=admin@example.com

# LLM
LLM_MODEL_NAME=hf.co/meta-llama/Llama-3.2-3B-Instruct
LLM_TIMEOUT_SECONDS=120
LLM_BASE_URL=http://model-runner.docker.internal/engines

# Required before starting compose stack:
# hf auth login
# docker model run --detach hf.co/meta-llama/Llama-3.2-3B-Instruct
